# Copy this file to .env and fill in real values. Never commit .env to git.

APP_ENV=development

# Firebase — set FIREBASE_CREDENTIALS_JSON to the raw JSON string (for Railway)
# or a path to the service account file (for local dev)
FIREBASE_CREDENTIALS_JSON=firebase-credentials.json
FIREBASE_PROJECT_ID=project_id

# Groq API key for LLaMA 3 chatbot
GROQ_API_KEY=groq_api_key

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=allowed_urls

# Rate limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=30

# Model files directory (mounted into container at runtime)
MODEL_DIR=/app/models/files
